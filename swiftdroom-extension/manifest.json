{
  "manifest_version": 3,
  "name": "Swiftdroom — Job Application Co-Pilot",
  "version": "1.1.0",
  "description": "Autofill Workday, Greenhouse, and Lever job applications from your profile. Generate tailored AI answers in one click.",
  "permissions": ["storage", "activeTab", "sidePanel", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://swiftdroom.com/*",
    "https://www.swiftdroom.com/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Swiftdroom",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/form-detector.js", "content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://swiftdroom.com/*",
        "https://www.swiftdroom.com/*",
        "https://*.up.railway.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["content-connect.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
