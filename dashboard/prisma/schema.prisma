generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  NONE
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum ReferralEarningStatus {
  PENDING
  ELIGIBLE
  PAID
  CANCELED
}

model User {
  id                     String             @id @default(cuid())
  email                  String             @unique
  passwordHash           String
  name                   String?
  role                   UserRole           @default(USER)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  profile                Profile?
  personas               Persona[]
  applications           Application[]
  fieldMappings          FieldMapping[]
  jobFeedItems           JobFeedItem[]
  jobSearchPreference    JobSearchPreference?
  autoApplySettings      AutoApplySettings?
  autoApplyJobs          AutoApplyJob[]
  apiToken               String             @unique @default(cuid())
  onboardingComplete     Boolean            @default(false)
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  plan                   SubscriptionPlan   @default(NONE)
  subscriptionStatus     SubscriptionStatus @default(NONE)
  applicationsUsed       Int                @default(0)
  applicationsLimit      Int                @default(0)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  referralCode           String             @unique
  referredById           String?
  referredBy               User?              @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals                User[]             @relation("UserReferrals")
  referralDiscountUsed     Boolean            @default(false)
  signupPromoCode          String             @default("")
  referralEarnings         ReferralEarning[]  @relation("ReferrerEarnings")
  earningsAsReferee        ReferralEarning[]  @relation("RefereeEarnings")
  emailNotifyLogin         Boolean            @default(true)
  emailNotifyApplications  Boolean            @default(true)
  emailNotifyBilling       Boolean            @default(true)
  welcomeEmailSent         Boolean            @default(false)
  subscribeNudgeCount      Int                @default(0)
  subscribeNudgeLastSentAt DateTime?
  passwordResetToken       String?            @unique
  passwordResetExpiresAt   DateTime?
  swiftdroomEmail          String?            @unique
  inboxEmails              InboxEmail[]
}

model ReferralEarning {
  id                    String                @id @default(cuid())
  referrerId            String
  referrer              User                  @relation("ReferrerEarnings", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId        String                @unique
  referredUser          User                  @relation("RefereeEarnings", fields: [referredUserId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan
  subscriptionAmount    Float
  commissionPercent     Float                 @default(10)
  commissionAmount      Float
  status                ReferralEarningStatus @default(PENDING)
  eligibleAt            DateTime
  redemptionEmailSentAt DateTime?
  paidAt                DateTime?
  paidNote              String                @default("")
  stripeInvoiceId       String?               @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([referrerId])
  @@index([status, eligibleAt])
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String   @default("")
  firstName      String   @default("")
  lastName       String   @default("")
  email          String   @default("")
  phone          String   @default("")
  location       String   @default("")
  linkedinUrl    String   @default("")
  githubUrl      String   @default("")
  portfolioUrl   String   @default("")
  resumeText     String   @default("")
  resumeFileName String   @default("")
  resumeUrl      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Persona {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  focus          String   @default("")
  summary        String   @default("")
  skills         String   @default("")
  resumeText     String   @default("")
  resumeFileName String   @default("")
  resumeUrl      String   @default("")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Application {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          String
  role             String
  url              String
  status           String   @default("applied")
  personaId        String?
  notes            String   @default("")
  jobDescription   String   @default("")
  submittedAnswers Json?
  fieldsFilled     Int      @default(0)
  fieldsAttempted        Int       @default(0)
  followUpReminderSentAt DateTime?
  appliedAt              DateTime  @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([userId, url])
}

model FieldMapping {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain       String
  labelPattern String
  fieldKey     String
  createdAt    DateTime @default(now())

  @@unique([userId, domain, labelPattern])
  @@index([userId])
}

model StripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

model JobListing {
  id          String        @id @default(cuid())
  externalId  String
  source      String
  company     String
  title       String
  description String        @default("")
  applyUrl    String
  location    String        @default("")
  region      String        @default("us")
  remote      Boolean       @default(false)
  postedAt    DateTime?
  atsType     String        @default("")
  feedItems   JobFeedItem[]
  autoApplyJobs AutoApplyJob[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([source, externalId])
  @@index([region, postedAt])
}

model JobFeedItem {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId String
  jobListing   JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  personaId    String?
  score        Float      @default(0)
  matchReason  String     @default("")
  status       String     @default("recommended")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, jobListingId])
  @@index([userId, status, score])
}

model JobSearchPreference {
  userId          String    @id
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRole      String    @default("")
  region          String    @default("all")
  remoteOnly      Boolean   @default(false)
  personaId       String?
  lastRefreshedAt DateTime?
  updatedAt       DateTime  @updatedAt
}

model AutoApplySettings {
  userId        String    @id
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled       Boolean   @default(false)
  minMatchScore Int       @default(75)
  dailyLimit    Int       @default(10)
  coverLetter   String    @default("")
  pausedUntil   DateTime?
  totalApplied  Int       @default(0)
  updatedAt     DateTime  @updatedAt
}

model AutoApplyJob {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListingId String
  jobListing   JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  status       String     @default("pending")
  atsType      String     @default("")
  error        String     @default("")
  appliedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, jobListingId])
  @@index([userId, status, createdAt])
}

model InboxEmail {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toAlias      String
  fromEmail    String
  fromName     String   @default("")
  subject      String   @default("")
  bodyText     String   @default("")
  bodyHtml     String   @default("")
  imapUid          String   @default("")
  receivedAt       DateTime @default(now())
  isRead           Boolean  @default(false)
  isNotified       Boolean  @default(false)
  isVerification   Boolean  @default(false)
  pendingCode      String?  // extracted verification code, kept until a job claims it
  createdAt        DateTime @default(now())

  @@index([userId, receivedAt])
  @@index([imapUid])
}

model VisitorSession {
  id          String         @id @default(cuid())
  visitorId   String
  landingPath String         @default("/")
  referrer    String         @default("")
  utmSource   String         @default("")
  utmMedium   String         @default("")
  utmCampaign String         @default("")
  userAgent   String         @default("")
  startedAt   DateTime       @default(now())
  lastSeenAt  DateTime       @default(now())
  endedAt     DateTime?
  durationSec Int            @default(0)
  pageViews   Int            @default(0)
  events      VisitorEvent[]

  @@index([startedAt])
  @@index([visitorId])
  @@index([utmSource, utmMedium])
}

model VisitorEvent {
  id        String         @id @default(cuid())
  sessionId String
  session   VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  path      String         @default("")
  label     String         @default("")
  meta      Json?
  createdAt DateTime       @default(now())

  @@index([sessionId])
  @@index([type, createdAt])
  @@index([path])
}
