generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  NONE
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum ReferralEarningStatus {
  PENDING
  ELIGIBLE
  PAID
  CANCELED
}

model User {
  id                     String             @id @default(cuid())
  email                  String             @unique
  passwordHash           String
  name                   String?
  role                   UserRole           @default(USER)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  profile                Profile?
  personas               Persona[]
  applications           Application[]
  fieldMappings          FieldMapping[]
  apiToken               String             @unique @default(cuid())
  onboardingComplete     Boolean            @default(false)
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  plan                   SubscriptionPlan   @default(NONE)
  subscriptionStatus     SubscriptionStatus @default(NONE)
  applicationsUsed       Int                @default(0)
  applicationsLimit      Int                @default(0)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  referralCode           String             @unique
  referredById           String?
  referredBy               User?              @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals                User[]             @relation("UserReferrals")
  referralDiscountUsed     Boolean            @default(false)
  referralEarnings         ReferralEarning[]  @relation("ReferrerEarnings")
  earningsAsReferee        ReferralEarning[]  @relation("RefereeEarnings")
}

model ReferralEarning {
  id                    String                @id @default(cuid())
  referrerId            String
  referrer              User                  @relation("ReferrerEarnings", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId        String                @unique
  referredUser          User                  @relation("RefereeEarnings", fields: [referredUserId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan
  subscriptionAmount    Float
  commissionPercent     Float                 @default(10)
  commissionAmount      Float
  status                ReferralEarningStatus @default(PENDING)
  eligibleAt            DateTime
  redemptionEmailSentAt DateTime?
  paidAt                DateTime?
  paidNote              String                @default("")
  stripeInvoiceId       String?               @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([referrerId])
  @@index([status, eligibleAt])
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String   @default("")
  firstName      String   @default("")
  lastName       String   @default("")
  email          String   @default("")
  phone          String   @default("")
  location       String   @default("")
  linkedinUrl    String   @default("")
  githubUrl      String   @default("")
  portfolioUrl   String   @default("")
  resumeText     String   @default("")
  resumeFileName String   @default("")
  resumeUrl      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Persona {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  focus          String   @default("")
  summary        String   @default("")
  skills         String   @default("")
  resumeText     String   @default("")
  resumeFileName String   @default("")
  resumeUrl      String   @default("")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String
  role      String
  url       String
  status    String   @default("applied")
  personaId String?
  notes     String   @default("")
  appliedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model FieldMapping {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain       String
  labelPattern String
  fieldKey     String
  createdAt    DateTime @default(now())

  @@unique([userId, domain, labelPattern])
  @@index([userId])
}

model StripeEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}
