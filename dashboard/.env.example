# Optional — only for running locally. Production uses Railway/Vercel Variables.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="swiftdroom-dev-secret-change-in-production"
ADMIN_EMAIL="you@company.com"
# Production: https://swiftdroom.com | Local: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# After Chrome Web Store publish — full listing URL
NEXT_PUBLIC_CHROME_WEB_STORE_URL="https://chromewebstore.google.com/detail/ficlpmiflbjkgegelneegohcbimjhnnb"
# Split deploy: Vercel frontend → Railway API (leave empty for same-origin / local)
NEXT_PUBLIC_API_URL=""
OPENAI_API_KEY=""

# Stripe (optional for local dev)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# Firebase (optional for local dev)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""
