# Local dev only — copy to dashboard/.env
# Production: use Railway + Vercel dashboards (see docs/ENVIRONMENT.md)

# --- Local (single server) ---
APP_URL=http://localhost:3000
API_URL=
CHROME_WEB_STORE_URL=https://chromewebstore.google.com/detail/ficlpmiflbjkgegelneegohcbimjhnnb

# --- Secrets (local or Railway only in production) ---
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=swiftdroom-dev-secret-change-in-production
ADMIN_EMAIL=you@company.com
OPENAI_API_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

