{
  "manifest_version": 3,
  "name": "Swiftdroom",
  "version": "1.0.0",
  "description": "AI-powered job application co-pilot. Autofill forms and generate tailored answers.",
  "permissions": ["storage", "activeTab", "sidePanel", "scripting"],
  "host_permissions": ["<all_urls>", "http://localhost:3000/*", "https://*.up.railway.app/*", "https://*.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Swiftdroom",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/form-detector.js", "content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
