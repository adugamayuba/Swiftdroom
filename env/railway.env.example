# Railway — paste into Service → Variables (Raw Editor)
# Secrets only. Do not commit real values.

DATABASE_URL=
# Neon direct URL (no -pooler). Required for automatic prisma migrate deploy on Railway deploy + startup.
DIRECT_URL=
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
APP_URL=https://swiftdroom.com
ALLOWED_ORIGINS=https://swiftdroom.com,https://www.swiftdroom.com
NODE_ENV=production

OPENAI_API_KEY=
JSEARCH_RAPIDAPI_KEY=
# Optional alias if you already use RAPIDAPI_KEY elsewhere:
# RAPIDAPI_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_COUPON_REFEREE_20=
STRIPE_PROMO_WELCOME=promo_1TgtY2E1gbGoJXOAWt84xU2O

# Optional — Google Ads conversion tracking (gtag)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-18229964298
# Optional: conversion label from Google Ads → Goals → Conversions
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Protects /api/cron/referrals, /api/cron/jobs-ingest, and /api/cron/nudges
CRON_SECRET=
RESEND_API_KEY=
EMAIL_FROM=Swiftdroom <noreply@swiftdroom.com>

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
